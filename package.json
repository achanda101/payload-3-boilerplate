{
  "name": "uafanp-payload",
  "version": "1.0.0",
  "description": "A multilingual grants and funding portal built with Payload CMS, Next.js, and PostgreSQL, designed to streamline the application process for grant seekers and enhance the management experience for administrators.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation next lint --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation payload migrate && cross-env NODE_OPTIONS=--no-deprecation next start"
  },
  "dependencies": {
    "@clocklimited/payload-2fa": "3.0.0-beta.1",
    "@modelcontextprotocol/sdk": "1.25.2",
    "@payloadcms/db-postgres": "3.74.0",
    "@payloadcms/live-preview-react": "3.74.0",
    "@payloadcms/next": "3.74.0",
    "@payloadcms/payload-cloud": "3.74.0",
    "@payloadcms/plugin-form-builder": "3.74.0",
    "@payloadcms/plugin-mcp": "3.74.0",
    "@payloadcms/plugin-nested-docs": "3.74.0",
    "@payloadcms/plugin-redirects": "3.74.0",
    "@payloadcms/plugin-search": "3.74.0",
    "@payloadcms/plugin-seo": "3.74.0",
    "@payloadcms/richtext-lexical": "3.74.0",
    "@payloadcms/storage-s3": "3.74.0",
    "@payloadcms/ui": "3.74.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-visually-hidden": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "embla-carousel-react": "^8.6.0",
    "embla-carousel-wheel-gestures": "^8.1.0",
    "geist": "^1.3.1",
    "graphql": "^16.9.0",
    "js-cookie": "^3.0.5",
    "jsonwebtoken": "9.0.2",
    "lucide-react": "^0.469.0",
    "next": "^15.4.10",
    "payload": "3.74.0",
    "payload-admin-bar": "^1.0.6",
    "plaiceholder": "^3.0.0",
    "prism-react-renderer": "^2.4.0",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-hook-form": "^7.54.2",
    "react-player": "^3.4.0",
    "sharp": "^0.34.0",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^13.5.7",
    "@payloadcms/eslint-config": "^1.1.1",
    "@tailwindcss/typography": "^0.5.15",
    "@types/escape-html": "^1.0.4",
    "@types/js-cookie": "^3.0.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "22.5.4",
    "@types/react": "npm:types-react@rc",
    "@types/react-dom": "npm:types-react-dom@rc",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "autoprefixer": "^10.4.20",
    "copyfiles": "^2.4.1",
    "dotenv": "^17.3.1",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.21.0",
    "typescript": "5.7.2"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "npm:types-react@rc",
      "@types/react-dom": "npm:types-react-dom@rc",
      "@payloadcms/plugin-cloud-storage": "3.74.0",
      "@modelcontextprotocol/sdk": "1.25.2"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "overrides": {
    "@types/react": "npm:types-react@rc",
    "@types/react-dom": "npm:types-react-dom@rc",
    "@modelcontextprotocol/sdk": "1.25.2"
  }
}
