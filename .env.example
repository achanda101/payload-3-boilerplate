# Database connection string
DATABASE_URI=postgres://postgres:postgres@localhost:5432/<your-db-name>

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Enable/Disable S3 storage
# Set to 'true' to use S3-compatible storage (Cloudflare R2, AWS S3, Supabase, etc.)
# Set to 'false' to use local filesystem (not recommended for files > 1MB due to Next.js Server Actions limit)
S3_ENABLED=true

NEXT_PUBLIC_SHOW_COLUMN_INDICATORS=false
NODE_ENV=development
DEMO_EMAIL=demo@example.com
DEMO_PASSWORD=demopassword

# S3-Compatible Storage Configuration (Cloudflare R2, AWS S3, Supabase, etc.)
# For Cloudflare R2:
#   - Get credentials from: Cloudflare Dashboard > R2 > Manage R2 API Tokens
#   - Endpoint format: https://<account-id>.r2.cloudflarestorage.com
#   - Region: 'auto' for R2
# For AWS S3:
#   - Endpoint: Leave blank or use custom endpoint
#   - Region: Your AWS region (e.g., 'us-east-1')
# For Supabase:
#   - Get from: Project Settings > Storage
#   - Endpoint format: https://<project-ref>.supabase.co/storage/v1/s3
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_BUCKET=payload-uploads
S3_REGION=auto
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
